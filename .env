# ================================================
# OPA5 SaaS — Variáveis de Ambiente
# Copie para .env e preencha com seus dados reais
# ================================================

# ── App ──────────────────────────────────────────
APP_NAME="OPA5 SaaS"
APP_ENV=development        # development | production
SECRET_KEY=troque_por_segredo_longo_e_aleatorio_aqui
FRONTEND_URL=http://localhost:3000

# ── Banco de dados ───────────────────────────────
# DEV (SQLite — sem instalar nada):
DATABASE_URL=sqlite:///./data/opa5.db

# PRODUÇÃO (PostgreSQL no Railway/Supabase):
# DATABASE_URL=postgresql://user:senha@host:5432/opa5

# ── OpenAI ───────────────────────────────────────
OPENAI_API_KEY=sk-proj-...
OPENAI_MODEL=gpt-4o-mini

